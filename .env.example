# HARDO — environment variables (.env.example)
# Copy to .env.local and fill in real values. Never commit real secrets.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Site ---
NEXT_PUBLIC_SITE_HOST=hardo.app
NEXT_PUBLIC_SITE_PROTO=https
NODE_ENV=development

# --- Speech-to-text ---
STT_PRIMARY=deepgram
STT_FALLBACK=openai
DEEPGRAM_API_KEY=your-deepgram-key
# Optional: used by the OpenAI STT fallback SDK
# OPENAI_API_KEY=your-openai-key

# --- LemonSqueezy (billing, Merchant of Record) ---
LEMONSQUEEZY_API_KEY=your-lemonsqueezy-api-key
LEMONSQUEEZY_STORE_ID=your-store-id
LEMONSQUEEZY_VARIANT_ID=your-variant-id
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-signing-secret
LEMONSQUEEZY_RPC_SECRET=your-rpc-secret

# --- Email (Resend) ---
RESEND_API_KEY=your-resend-key
RESEND_AUDIENCE_ID=your-audience-id
EMAIL_FROM=HARDO <hello@hardo.app>
SUBSCRIBE_NOTIFY_TO=hello@hardo.app
